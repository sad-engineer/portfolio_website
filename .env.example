# --- Публичные контакты/ссылки (подставляются в шаблоны) ---
PHONE_E164=         # Телефон в формате E.164
GITHUB_URL=         # Ссылка на профиль вGitHub
TELEGRAM_URL=       # Ссылка на Telegram
PROFI_RU_URL=       # Ссылка на профиль на сайте Profi.ru
HH_RU_URL=          # Ссылка на резюме HH.ru
FREELANCE_RU_URL=   # Ссылка на профиль на сайте Freelance.ru

# --- SMTP (исходящая почта для уведомлений о заявках) ---
FEEDBACK_SMTP_HOST=         # Хост SMTP сервера
FEEDBACK_SMTP_PORT=         # Порт SMTP сервера
FEEDBACK_SMTP_USER=         # Логин SMTP сервера
FEEDBACK_SMTP_PASSWORD=     # Пароль SMTP сервера
FEEDBACK_SMTP_TO=           # Email адрес получателя

# --- Telegram Bot API (уведомления в личку/группу) ---
FEEDBACK_TELEGRAM_BOT_TOKEN=   # Токен Telegram бота
FEEDBACK_TELEGRAM_CHAT_ID=     # ID чата Telegram
FEEDBACK_TELEGRAM_TIMEOUT_SECONDS=30  # Таймаут запроса в Telegram API (в секундах)
FEEDBACK_TELEGRAM_PROXY_URL=          # HTTPS прокси для Telegram (опционально), пример: http://user:pass@host:port

# --- Cloudflare Turnstile (антиспам защита) ---
FEEDBACK_TURNSTILE_SITE_KEY=                    # Публичный ключ Cloudflare Turnstile
FEEDBACK_TURNSTILE_SECRET_KEY=                  # Секретный ключ Cloudflare Turnstile
FEEDBACK_TURNSTILE_TIMEOUT_SECONDS=8            # Таймаут проверки Turnstile (в секундах)

# --- Ограничения на количество запросов ---
FEEDBACK_DELIVERY_RETRIES=2                     # Количество попыток доставки заявок (в случае ошибки)
FEEDBACK_DELIVERY_RETRY_DELAY_MS=400            # Задержка между попытками доставки заявок (в миллисекундах)
FEEDBACK_RATE_LIMIT_MAX_REQUESTS=3              # Максимальное количество запросов за временное окно
FEEDBACK_RATE_LIMIT_WINDOW_SECONDS=600          # Временное окно (в секундах)
FEEDBACK_RATE_LIMIT_MIN_INTERVAL_SECONDS=120    # Минимальный интервал между запросами (в секундах)
FEEDBACK_SMTP_TIMEOUT_SECONDS=25                # Таймаут SMTP соединения (в секундах)
FEEDBACK_SMTP_SECURITY=ssl                      # Варианты: ssl | starttls | auto

# --- PostgreSQL (хранение заявок обратной связи) ---
FEEDBACK_DATABASE_URL=      # postgresql://USER:PASSWORD@HOST:PORT/DBNAME